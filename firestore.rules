rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "nupha7@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidPersonnel(data) {
      return data.keys().hasAll(['name', 'section', 'instrument', 'angkatan', 'avatarUrl', 'createdAt'])
        && data.name is string && data.name.size() > 0
        && data.angkatan is string
        && data.createdAt != null;
    }

    function isValidGallery(data) {
      return data.keys().hasAll(['title', 'imageUrl', 'isLarge', 'createdAt'])
        && data.title is string
        && data.imageUrl is string
        && data.isLarge is bool
        && data.createdAt != null;
    }

    function isValidSettings(data) {
      return data.schoolName is string && data.schoolName.size() <= 100;
    }

    match /personnel/{personId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId) && isValidSettings(request.resource.data);
    }
  }
}
